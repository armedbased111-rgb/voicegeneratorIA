{
  "name": "voicegeneratoria",
  "version": "0.1.0",
  "description": "Text-to-Speech GUI pour la prod rap",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.triplesept.voicegeneratoria",
    "productName": "VoiceGeneratorIA",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "!out/renderer/assets/*.woff",
      "out/renderer/assets/*.woff2",
      "out/renderer/assets/*.css",
      "out/renderer/assets/*.js",
      "out/renderer/index.html"
    ],
    "extraResources": [
      { "from": "../voice.py",     "to": "voice.py" },
      { "from": "../presets.json", "to": "presets.json" },
      { "from": "../.venv",        "to": ".venv" }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "dmg": {
      "title": "VoiceGeneratorIA",
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "@fontsource/geist": "^5.0.0",
    "@fontsource/geist-mono": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17"
  }
}
