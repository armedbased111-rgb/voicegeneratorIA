{
  "name": "echo",
  "version": "0.2.0",
  "description": "ECHO — Voice generator for rap production",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.triplesept.echo",
    "productName": "ECHO",
    "copyright": "Copyright © 2026",
    "icon": "build/icon",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["out/**/*"],
    "extraResources": [
      { "from": "resources/presets.json", "to": "presets.json" }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "extraResources": [
        { "from": "dist-bin/voice", "to": "voice" }
      ]
    },
    "dmg": {
      "title": "ECHO",
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "extraResources": [
        { "from": "dist-bin/voice.exe", "to": "voice.exe" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "@fontsource/geist": "^5.0.0",
    "@fontsource/geist-mono": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17"
  }
}
